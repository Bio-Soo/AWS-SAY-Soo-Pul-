# Soo-Pul Frontend — Environment Template
#
# Build-time variables (Vite reads VITE_* prefixed values).
# Vite file precedence (highest→lowest):
#   .env.production.local    (gitignored, personal override)
#   .env.production          (gitignored — auto-generated by scripts/deploy-frontend.sh)
#   .env.development.local   (gitignored, personal override for dev)
#   .env.development         (commit-safe dev defaults)
#   .env.example             (this file)

# ────────────────────────────────────────────────────
# Production / staging — Cognito + API
# ────────────────────────────────────────────────────
VITE_AWS_REGION=ap-northeast-2
VITE_COGNITO_USER_POOL_ID=ap-northeast-2_xxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=https://your-pool.auth.ap-northeast-2.amazoncognito.com

# API base — leave empty if frontend is served from same CloudFront (/api/* proxies to FastAPI)
VITE_API_BASE=

# Force backend.sessions.* (real Step Functions trigger), even when VITE_USE_MOCK=true.
# Use case: SMART OAuth is mocked for demos, but diagnosis goes through real backend + SFN.
VITE_USE_BACKEND_SESSIONS=1

# ────────────────────────────────────────────────────
# Dev / mock toggles (npm run dev)
# ────────────────────────────────────────────────────
# true  → mock data + smartLauncher no-op
# false → real SMART OAuth flow
VITE_USE_MOCK=true

# Session TTL in minutes. Default 60. Security policy: 15~480.
VITE_SESSION_TIMEOUT_MIN=60

# FHIR auth mode:
#   smart : SMART on FHIR OAuth2 (EHR-launched, fhirclient v2)
#   none  : raw FHIR REST (HAPI without OAuth)
VITE_FHIR_AUTH_MODE=smart

# Only used when VITE_FHIR_AUTH_MODE=none
# VITE_FHIR_BASE_URL=https://example.org/fhir

# Soo-Pul deployment configuration
# Copy this to .env and fill in your AWS-specific values.
# DO NOT commit .env to git.

# ── AWS account ─────────────────────────────────────────────
AWS_ACCOUNT_ID=123456789012
AWS_REGION=ap-northeast-2

# ── S3 ──────────────────────────────────────────────────────
# Single deployment bucket — Lambda artifacts, frontend, mock EMR data
S3_BUCKET=your-deployment-bucket-name

# ── Aurora PostgreSQL ───────────────────────────────────────
AURORA_CLUSTER_ENDPOINT=your-aurora.cluster-xxxxx.ap-northeast-2.rds.amazonaws.com
AURORA_DB_NAME=soopul
AURORA_SCHEMA=soopulai
AURORA_DB_USER=app_user

# ── Secrets Manager — secret NAMES (not values) ─────────────
# Create these in Secrets Manager with the actual passwords.
SECRET_AURORA_MASTER=soopul/aurora/master
SECRET_AURORA_APP_USER=soopul/aurora/app-user

# ── VPC config (Lambda VPC + RDS access) ────────────────────
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
# At least 2 subnets in AZs with NAT egress (for Secrets Manager / Bedrock)
LAMBDA_SUBNET_IDS=subnet-aaa,subnet-bbb
# Security group allowed to reach Aurora:5432 (typically a dedicated SG)
LAMBDA_SECURITY_GROUP=sg-xxxxxxxx

# ── Cognito (auth) ──────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-northeast-2_xxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=https://your-domain.auth.ap-northeast-2.amazoncognito.com

# ── Step Functions ──────────────────────────────────────────
STEPFN_NAME=soonet-pulmonary-pipeline
STEPFN_ROLE_NAME=soonet-pulmonary-stepfn-role

# ── Bedrock ─────────────────────────────────────────────────
# For ap-northeast-2: use inference profiles (foundation models reject on-demand).
BEDROCK_REGION=ap-northeast-2
BEDROCK_MODEL_PHASE4=apac.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_RAG=anthropic.claude-3-5-sonnet-20240620-v1:0

# ── SageMaker (Phase 2 CXR DenseNet) ────────────────────────
SAGEMAKER_ENDPOINT=your-cxr-densenet-endpoint

# ── FastAPI backend (EC2) ───────────────────────────────────
EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
FASTAPI_PORT=8000
# Generated secret for cron-triggered worklist preload
CRON_PRELOAD_TOKEN=replace-with-random-32+-char-token

# ── CloudFront (frontend) ───────────────────────────────────
CLOUDFRONT_DISTRIBUTION_ID=Exxxxxxxxxxxxx
CLOUDFRONT_DOMAIN=dxxxxxxxxxxxxx.cloudfront.net

# ── Dev toggles (do NOT use in production) ──────────────────
# Set to 1 to bypass Cognito JWT validation in FastAPI
DEV_BYPASS_AUTH=0
# Set to 1 to skip SFN start (returns mock execution_arn)
DEV_STEPFN_DUMMY=0
